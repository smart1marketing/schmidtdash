# Ecwid API Configuration
# Copy this file to .env and fill in your actual credentials
# NOTE: Never commit .env to GitHub - it's in .gitignore

# Your Ecwid Store ID (found in dashboard or settings)
ECWID_STORE_ID=your_store_id_here

# Your Ecwid API Token (generate in Settings → API Tokens)
# Make sure it has read_orders and read_products scopes
ECWID_API_TOKEN=your_api_token_here

# Server configuration
PORT=3000
NODE_ENV=production

# Optional: Set timezone for 2 AM cron job
# TZ=America/Chicago
